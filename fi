                            display: none
                        }
                    }

                    .template-desc {
                        margin-top: var(--space-4);
                        font-size: var(--text-base)
                    }

                    .view-all {
                        margin-top: 22px
                    }

                    .slides {
                        position: absolute;
                        inset: 0 var(--space-5) auto 380px;
                        gap: 10px var(--space-2);
                        margin: 0
                    }

                    .slide {
                        padding-bottom: var(--space-5)
                    }

                    .slide-title {
                        position: absolute;
                        inset: auto auto 0 0;
