            }

            @media(min-width: 40em) {
                .kit2 .social-links {
                    flex-direction:row;
                    margin: 0 0 var(--space-8)
                }
            }

            /* call to action */
            .call-to-action {
                --title-color: var(--gray-100);
                --subtitle-color: var(--gray-100);
                --icon-color: var(--gray-100);
                --title-font-family: var(--font-display);
                --subtitle-font-family: var(--font-body);
