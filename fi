                                                <script>
                                                    require(["jquery", "goatee", "sv_urlLib", "sv_mathLib", 'lodash', "sv_site"], function($, goatee, urlLib, mathLib, lodash, sv_site) {
                                                        var root = $("[data-sv-weatherWidget]");
                                                        var template = $("[data-weatherwidget-template]").html();
                                                        var dropdownTemplate = $("[data-weather-dropdown-template]").html();
                                                        var settings = {
                                                            "unit_of_measure": "f"
                                                        };
                                                        var unitToggle = root.find('[data-unit-toggle]');
                                                        let currentUnitOfMeasure = settings.unit_of_measure;
                                                        let weatherData = {};
                                                        let weatherDataCelsius = {};
                                                        var url = urlLib.build({
                                                            path: "/plugins/core/svapi/",
                                                            get: {
                                                                service: "weatherv2",
                                                                endpoint: "latlng",
                                                                serviceArgs: JSON.stringify({
                                                                    lat: sv_site.siteConfig.latitude,
                                                                    lng: sv_site.siteConfig.longitude,
                                                                    unit: settings.unit_of_measure
                                                                })
                                                            }
                                                        });

                                                        $.get(url, function(res) {
                                                            if (res.success !== true) {
                                                                return;
                                                            }

                                                            res.data.forecast.splice(5);
                                                            // trim forecast to first 5 days
                                                            weatherData = res.data;
                                                            weatherDataCelsius = convertToCelsius(lodash.cloneDeep(weatherData));

                                                            renderWeather(weatherData);
                                                        });

                                                        function convertToCelsius(data) {
                                                            data.current.temp = Math.round(mathLib.fToC(data.current.temp));

                                                            data.forecast.forEach(day => {
                                                                day.high = Math.round(mathLib.fToC(day.high));
                                                                day.low = Math.round(mathLib.fToC(day.low));
                                                            }
                                                            );

                                                            return data;
                                                        }

                                                        function renderWeather(data) {
                                                            var html = goatee.fill(template, data, {
                                                                dropdownTemplate: dropdownTemplate
                                                            }, {
                                                                currentUnit: currentUnitOfMeasure,
                                                                inactiveUnit: 'Celsius'
                                                            });
                                                            root.html(html);
                                                            $("[data-weather-cont]").html(root.clone());

                                                            $("[data-sv-weather-toggle]").on("click", function() {
                                                                var dropdown = $("[data-sv-weather-dropdown]");
                                                                dropdown.toggleClass("open");
                                                                var isActive = dropdown.hasClass("open");
                                                                $(this).attr("aria-expanded", isActive);
                                                            });

                                                            $("[data-unit-toggle]").on("click", function() {
                                                                toggleWeather();
                                                            });
                                                        }

                                                        function toggleWeather() {
                                                            var html = '';
                                                            var dropdown = $("[data-sv-weather-dropdown]");
                                                            currentUnitOfMeasure = (currentUnitOfMeasure === 'f') ? 'c' : 'f';

                                                            if (currentUnitOfMeasure === 'f') {
                                                                html = goatee.fill(dropdownTemplate, weatherData, {}, {
                                                                    currentUnit: currentUnitOfMeasure,
                                                                    inactiveUnit: 'Celsius'
                                                                });
                                                            } else if (currentUnitOfMeasure === 'c') {
                                                                html = goatee.fill(dropdownTemplate, weatherDataCelsius, {}, {
                                                                    currentUnit: currentUnitOfMeasure,
                                                                    inactiveUnit: 'Fahrenheit'
                                                                });
                                                            }

                                                            dropdown.html(html);

                                                            $("[data-unit-toggle]").on("click", function() {
                                                                toggleWeather();
                                                            });
                                                        }

                                                    });
                                                </script>
